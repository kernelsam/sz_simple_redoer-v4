# Example configuration for sz_simple_redoer
# Copy this to .env and modify values as needed

# Required: Senzing engine configuration (JSON format)
# This tells Senzing how to connect to your data store
SENZING_ENGINE_CONFIGURATION_JSON={"PIPELINE":{"CONFIGPATH":"/etc/opt/senzing","RESOURCEPATH":"/opt/senzing/g2/resources","SUPPORTPATH":"/opt/senzing/data"},"SQL":{"CONNECTION":"sqlite3://na:na@/tmp/sqlite/G2C.db"}}

# Optional: Logging level for troubleshooting
# Options: debug, info, warning, error, critical
SENZING_LOG_LEVEL=info

# Optional: Number of worker threads (0 = auto-detect)
# Higher values = more parallel processing but more memory usage
SENZING_THREADS_PER_PROCESS=4

# Optional: Seconds before a record is considered long-running
# Used for monitoring and alerts
LONG_RECORD=300

# Optional: Seconds to pause when no redo records are available
# Lower values = more responsive but higher CPU usage when idle
SENZING_REDO_SLEEP_TIME_IN_SECONDS=60